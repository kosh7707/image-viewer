{
  "name": "image-viewer",
  "version": "0.1.0",
  "description": "Minimal fullscreen Electron image viewer (JPEG/PNG/WebP/GIF) for Windows",
  "main": "dist/src/main/main.js",
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
    "start": "npm run build && electron .",
    "dev": "tsc -w & electron .",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "dist": "npm run build && electron-builder"
  },
  "keywords": [
    "electron",
    "image-viewer"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "31.7.7",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "gifuct-js": "^2.1.2"
  }
}
