{
  "name": "image-viewer",
  "version": "0.5.0",
  "description": "Minimal fullscreen Electron image viewer (JPEG/PNG/WebP/GIF) for Windows",
  "main": "dist/src/main/main.js",
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js && node scripts/bundle-renderer.js",
    "start": "npm run build && electron .",
    "dev": "tsc -w & electron .",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "dist": "npm run build && electron-builder",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "electron",
    "image-viewer"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "electron": "42.2.0",
    "electron-builder": "26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.0"
  },
  "dependencies": {
    "gifuct-js": "^2.1.2",
    "image-size": "^2.0.2"
  }
}
